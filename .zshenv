export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export TERMINAL=alacritty
export EDITOR=vim
export VISUAL=vim
export BROWSER=brave
export FZF_DEFAULT_OPS="--extended"
export MANPAGER='/bin/zsh -c "vim -Rn -c \"set buftype=nofile showtabline=0 ft=man ts=4 nomod nolist nornu nonu noma\" -c \"normal L\" -c \"nmap q :qa<CR>\"</dev/tty <(col -b)"'

export PATH="/home/josh/.local/bin:$PATH"

export TERM=xterm-256color

export OPENSSL_DIR=/usr/bin/openssl
export QT_QPA_PLATFORMTHEME=qt5ct

export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache
export XDG_DATA_HOME=$HOME/.local/share

export WALLPAPERS_DIR=$HOME/Pictures/Wallpapers
export SCREENSHOTS_DIR=$HOME/Pictures/Screenshots
export SCRIPTS_DIR=$HOME/.local/bin

export LESSHISTFILE=$XDG_CACHE_HOME/less_history
export LESSHISTSIZE=500

